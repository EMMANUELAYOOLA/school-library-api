{
  "info": {
    "name": "School Library Management API",
    "description": "Complete API collection for School Library Management System",
    "schema": "https:
  },
  "item": [
    {
      "name": "🔓 Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  "staffId": "LIB001",\n  "password": "password123"\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendants/login",
              "host": ["{{base_url}}"],
              "path": ["attendants", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "👤 Authors",
      "item": [
        {
          "name": "Create Author",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  "name": "Chinua Achebe",\n  "bio": "Nigerian novelist and poet"\n}"
            },
            "url": {
              "raw": "{{base_url}}/authors",
              "host": ["{{base_url}}"],
              "path": ["authors"]
            }
          }
        },
        {
          "name": "Get All Authors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/authors",
              "host": ["{{base_url}}"],
              "path": ["authors"]
            }
          }
        },
        {
          "name": "Get Single Author",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/authors/{{author_id}}",
              "host": ["{{base_url}}"],
              "path": ["authors", "{{author_id}}"]
            }
          }
        },
        {
          "name": "Update Author",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  "name": "Updated Name",\n  "bio": "Updated bio"\n}"
            },
            "url": {
              "raw": "{{base_url}}/authors/{{author_id}}",
              "host": ["{{base_url}}"],
              "path": ["authors", "{{author_id}}"]
            }
          }
        },
        {
          "name": "Delete Author",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/authors/{{author_id}}",
              "host": ["{{base_url}}"],
              "path": ["authors", "{{author_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "📕 Books",
      "item": [
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  "title": "Things Fall Apart",\n  "isbn": "ISBN-9780385474542",\n  "authors": ["{{author_id}}"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/books",
              "host": ["{{base_url}}"],
              "path": ["books"]
            }
          }
        },
        {
          "name": "Get All Books (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/books?page=1&limit=10&search=things",
              "host": ["{{base_url}}"],
              "path": ["books"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"},
                {"key": "search", "value": "things"}
              ]
            }
          }
        },
        {
          "name": "Get Single Book",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/books/{{book_id}}",
              "host": ["{{base_url}}"],
              "path": ["books", "{{book_id}}"]
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  "title": "Updated Title"\n}"
            },
            "url": {
              "raw": "{{base_url}}/books/{{book_id}}",
              "host": ["{{base_url}}"],
              "path": ["books", "{{book_id}}"]
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/books/{{book_id}}",
              "host": ["{{base_url}}"],
              "path": ["books", "{{book_id}}"]
            }
          }
        },
        {
          "name": "Borrow Book",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  "studentId": "{{student_id}}",\n  "attendantId": "{{attendant_id}}",\n  "returnDate": "2026-05-01"\n}"
            },
            "url": {
              "raw": "{{base_url}}/books/{{book_id}}/borrow",
              "host": ["{{base_url}}"],
              "path": ["books", "{{book_id}}", "borrow"]
            }
          }
        },
        {
          "name": "Return Book",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/books/{{book_id}}/return",
              "host": ["{{base_url}}"],
              "path": ["books", "{{book_id}}", "return"]
            }
          }
        },
        {
          "name": "Get Overdue Books",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/books/overdue",
              "host": ["{{base_url}}"],
              "path": ["books", "overdue"]
            }
          }
        }
      ]
    },
    {
      "name": "🎓 Students",
      "item": [
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  "name": "John Doe",\n  "email": "john@school.edu",\n  "studentId": "STU001"\n}"
            },
            "url": {
              "raw": "{{base_url}}/students",
              "host": ["{{base_url}}"],
              "path": ["students"]
            }
          }
        },
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/students",
              "host": ["{{base_url}}"],
              "path": ["students"]
            }
          }
        },
        {
          "name": "Get Single Student",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/students/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["students", "{{student_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "👔 Attendants",
      "item": [
        {
          "name": "Create Attendant",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  "name": "Jane Smith",\n  "staffId": "LIB001",\n  "password": "password123"\n}"
            },
            "url": {
              "raw": "{{base_url}}/attendants",
              "host": ["{{base_url}}"],
              "path": ["attendants"]
            }
          }
        },
        {
          "name": "Get All Attendants",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/attendants",
              "host": ["{{base_url}}"],
              "path": ["attendants"]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http:
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "author_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "book_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "student_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "attendant_id",
      "value": "",
      "type": "string"
    }
  ]
}
